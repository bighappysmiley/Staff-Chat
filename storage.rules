rules_version = '2';

// Staff Chat — Cloud Storage rules for avatars and server icons.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isImageUnder(maxBytes) {
      return request.resource.size < maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    // Profile pictures: only the owner can upload their own avatar.
    match /avatars/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && isImageUnder(5 * 1024 * 1024);
    }

    // Server icons: any signed-in user can upload (UI restricts to admins;
    // tighten here with a Firestore lookup if you need hard enforcement).
    match /servers/{serverId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isImageUnder(5 * 1024 * 1024);
    }
  }
}
