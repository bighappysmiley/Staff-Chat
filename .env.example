# Firebase web config — copy this file to `.env` and fill in values from
# Firebase Console → Project settings → General → "Your apps" → Web app → SDK setup.
# All values are safe to expose in client code (they identify, not authorize);
# real protection comes from the Firestore/Storage security rules in this repo.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
